{
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/server.js": {
      "memory": 256,
      "maxDuration": 30,
      "includeFiles": "backend/**"
    }
  },
  "installCommand": "cd frontend && npm install && cd ../backend && npm install",
  "rootDirectory": "frontend"
}
