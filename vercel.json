{
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/server"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/api/fallback"
    }
  ],
  "functions": {
    "api/server.js": {
      "memory": 256,
      "maxDuration": 30,
      "includeFiles": "backend/**"
    },
    "api/fallback.js": {
      "memory": 128,
      "maxDuration": 10,
      "includeFiles": "frontend/dist/index.html"
    }
  },
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install && cd ../backend && npm install"
}
